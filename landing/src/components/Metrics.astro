---
const metrics = [
  { value: '0-100', label: 'Match Score por compatibilidad', color: 'text-primary' },
  { value: '3 fases', label: 'Plan de activación automático', color: 'text-secondary' },
  { value: '5 segmentos', label: 'Audiencias mapeadas por club', color: 'text-tertiary' },
  { value: 'vs medios', label: 'Comparativa de valor mediático', color: 'text-on-surface' },
];
---

<section class="relative py-32">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-0 left-1/4 w-[400px] h-[400px] rounded-full bg-secondary/5 blur-[120px]"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-6">
    <div class="text-center max-w-2xl mx-auto mb-20">
      <p class="text-xs font-medium uppercase tracking-widest text-secondary mb-4">Inteligencia de patrocinio</p>
      <h2 class="text-4xl md:text-5xl font-black tracking-tight text-on-surface" style="letter-spacing: -0.03em;">
        Lo que no se mide, no se puede mejorar
      </h2>
      <p class="text-lg text-on-surface-variant mt-6 leading-relaxed">
        Un patrocinador necesita justificar cada euro ante sus superiores. SponsorMatch te da las métricas para demostrar que tu propuesta es rentable.
      </p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-12">
      {metrics.map((metric) => (
        <div class="text-center">
          <p class={`text-4xl md:text-5xl font-black mb-3 ${metric.color}`} style="letter-spacing: -0.03em;">
            {metric.value}
          </p>
          <p class="text-xs uppercase tracking-widest text-on-surface-variant">{metric.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
