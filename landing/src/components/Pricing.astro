---
const plans = [
  {
    name: 'Starter',
    price: '0',
    period: '/mes',
    description: 'Para marcas que empiezan a explorar el patrocinio deportivo.',
    features: [
      'Acceso al marketplace',
      'Hasta 3 búsquedas guardadas',
      'Métricas básicas de clubes',
      'Mensajería limitada (10/mes)',
    ],
    cta: 'Empezar gratis',
    highlighted: false,
  },
  {
    name: 'Professional',
    price: '99',
    period: '/mes',
    description: 'Para marcas con estrategia activa de patrocinio.',
    features: [
      'Todo lo de Starter',
      'Hasta 10 búsquedas guardadas',
      'Métricas avanzadas + tendencias',
      'Recomendaciones IA',
      'Mensajería ilimitada',
      'Gestión de acuerdos',
    ],
    cta: 'Prueba 14 días gratis',
    highlighted: true,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: '',
    description: 'Para grandes marcas y agencias de marketing deportivo.',
    features: [
      'Todo lo de Professional',
      'API de integración',
      'Informes personalizados',
      'Account manager dedicado',
      'SLA 99.99%',
      'Onboarding personalizado',
    ],
    cta: 'Contactar ventas',
    highlighted: false,
  },
];
---

<section id="pricing" class="relative py-32">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] rounded-full bg-tertiary-container/5 blur-[120px]"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-6">
    <div class="text-center max-w-2xl mx-auto mb-20">
      <p class="text-xs font-medium uppercase tracking-widest text-primary mb-4">Precios</p>
      <h2 class="text-4xl md:text-5xl font-black tracking-tight text-on-surface mb-6" style="letter-spacing: -0.03em;">
        Un plan para cada etapa
      </h2>
      <p class="text-lg text-on-surface-variant">
        Empieza gratis y escala cuando lo necesites. Sin compromisos.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {plans.map((plan) => (
        <div class={`relative p-8 rounded-2xl transition-all duration-300 ${
          plan.highlighted
            ? 'bg-surface-container ring-1 ring-primary-container/30 shadow-[0_0_40px_rgba(37,99,235,0.1)]'
            : 'bg-surface-container hover:bg-surface-bright'
        }`}>
          {plan.highlighted && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 rounded-full bg-gradient-to-r from-primary-container to-secondary-container text-white text-xs font-semibold">
              Más popular
            </div>
          )}
          <p class="text-xs font-medium uppercase tracking-widest text-on-surface-variant mb-2">{plan.name}</p>
          <div class="flex items-baseline gap-1 mb-2">
            {plan.price !== 'Custom' && <span class="text-sm text-on-surface-variant">€</span>}
            <span class="text-4xl font-black text-on-surface">{plan.price}</span>
            {plan.period && <span class="text-sm text-on-surface-variant">{plan.period}</span>}
          </div>
          <p class="text-sm text-on-surface-variant mb-8">{plan.description}</p>
          <ul class="space-y-3 mb-8">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3 text-sm text-on-surface-variant">
                <svg class="w-4 h-4 text-secondary mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>
          <a href="/app" class={`block text-center py-3 rounded-lg font-semibold text-sm transition-all duration-300 ${
            plan.highlighted
              ? 'bg-gradient-to-r from-primary-container to-secondary-container text-white hover:shadow-[0_0_20px_rgba(37,99,235,0.4)]'
              : 'text-on-surface-variant hover:text-on-surface'
          }`} style={plan.highlighted ? '' : 'border: 1px solid rgba(67, 70, 85, 0.15);'}>
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
