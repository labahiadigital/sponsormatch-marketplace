---

---

<section class="relative min-h-screen flex items-center overflow-hidden pt-20">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 -left-32 w-[500px] h-[500px] rounded-full bg-primary-container/15 blur-[120px]"></div>
    <div class="absolute bottom-1/4 -right-32 w-[400px] h-[400px] rounded-full bg-secondary/10 blur-[100px]"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-tertiary-container/5 blur-[150px]"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-6 py-24 md:py-32">
    <div class="max-w-4xl">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-surface-container mb-8">
        <div class="w-2 h-2 rounded-full bg-secondary animate-pulse"></div>
        <span class="text-xs font-medium uppercase tracking-widest text-on-surface-variant">La plataforma que enamora al patrocinador</span>
      </div>

      <h1 class="text-5xl md:text-7xl lg:text-8xl font-black tracking-tight leading-[0.9] text-primary mb-8" style="letter-spacing: -0.04em;">
        No vendas logos.<br />
        <span class="text-on-surface">Vende audiencias,<br />contenido y ROI.</span>
      </h1>

      <p class="text-lg md:text-xl text-on-surface-variant max-w-2xl mb-12 leading-relaxed">
        Las empresas rechazan el 90% de las propuestas de patrocinio porque no resuelven sus problemas. SponsorMatch te da las herramientas para ofrecer lo que un patrocinador realmente necesita: audiencias segmentadas, planes de activación y retorno medible.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mb-20">
        <a href="/app" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-lg bg-gradient-to-r from-primary-container to-secondary-container text-white font-semibold text-base hover:shadow-[0_0_30px_rgba(37,99,235,0.5)] transition-all duration-300 transform hover:-translate-y-0.5">
          Descubre tu match ideal
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a href="#how-it-works" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-lg text-on-surface-variant font-medium text-base hover:text-on-surface transition-colors" style="border: 1px solid rgba(67, 70, 85, 0.15);">
          Ver cómo funciona
        </a>
      </div>

      <div class="grid grid-cols-3 gap-8 max-w-lg">
        <div>
          <p class="text-3xl md:text-4xl font-black text-on-surface">500+</p>
          <p class="text-xs uppercase tracking-widest text-on-surface-variant mt-1">Clubes con métricas</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-black text-secondary">+340%</p>
          <p class="text-xs uppercase tracking-widest text-on-surface-variant mt-1">ROI medio estimado</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-black text-tertiary">3 fases</p>
          <p class="text-xs uppercase tracking-widest text-on-surface-variant mt-1">Plan de activación</p>
        </div>
      </div>
    </div>
  </div>
</section>
