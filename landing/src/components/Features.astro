---
const features = [
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" /></svg>`,
    title: 'Calculadora de ROI',
    description: 'Estima el retorno de inversión antes de proponer un acuerdo. Valor mediático, coste por impresión y proyecciones de crecimiento para cada club.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>`,
    title: 'Mapa de audiencias',
    description: 'Segmentación real por club: Digital Natives, Fans Hardcore, Familias, Corporativo. Porque un patrocinador no compra deportes, compra audiencias.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>`,
    title: 'Match Score inteligente',
    description: 'Puntuación 0-100 de compatibilidad marca-club. Evalúa presupuesto, engagement, crecimiento y alineación de objetivos automáticamente.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>`,
    title: 'Plan de activación',
    description: 'Plantilla automática con acciones pre, durante y post-evento. Sorteos, streaming, UGC, acciones solidarias, meet & greet: todo con costes estimados.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z" /></svg>`,
    title: 'Métricas tipo medio',
    description: 'Cada club es un medio de comunicación. Compara su alcance con prensa local, radio y TV. Demuestra al patrocinador que tu audiencia vale más que la publicidad convencional.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>`,
    title: 'Territorio de marca único',
    description: 'Cada club tiene su territorio y propósito superior definidos. Identifica qué te diferencia y conecta con patrocinadores que comparten tus valores.',
  },
];
---

<section id="features" class="relative py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="max-w-2xl mb-20">
      <p class="text-xs font-medium uppercase tracking-widest text-secondary mb-4">Lo que necesita un patrocinador</p>
      <h2 class="text-4xl md:text-5xl font-black tracking-tight text-on-surface mb-6" style="letter-spacing: -0.03em;">
        Audiencias, contenido, ROI y un plan de activación
      </h2>
      <p class="text-lg text-on-surface-variant leading-relaxed">
        Las empresas no compran logos en camisetas. Compran plataformas de comunicación que conecten con audiencias, generen contenidos exclusivos y ofrezcan retorno medible. SponsorMatch te da las herramientas para demostrarlo.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((feature) => (
        <div class="group p-8 rounded-2xl bg-surface-container hover:bg-surface-bright transition-all duration-300 hover:shadow-[0_0_40px_rgba(37,99,235,0.08)]">
          <div class="w-12 h-12 rounded-xl bg-surface-low flex items-center justify-center text-primary mb-6 group-hover:bg-primary-container/20 transition-colors">
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="text-lg font-bold text-on-surface mb-3">{feature.title}</h3>
          <p class="text-sm text-on-surface-variant leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
