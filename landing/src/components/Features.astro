---
const features = [
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z" /></svg>`,
    title: 'Filtros inteligentes',
    description: 'Filtra por presupuesto, deporte, ubicación y demografía. Encuentra las oportunidades perfectas en segundos.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" /></svg>`,
    title: 'Métricas en tiempo real',
    description: 'Seguidores, engagement, alcance y tendencias actualizados al minuto para cada club y deportista.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>`,
    title: 'Recomendaciones IA',
    description: 'Algoritmos que analizan patrocinios anteriores y sugieren los clubes con mayor potencial de ROI.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z" /></svg>`,
    title: 'Búsquedas guardadas',
    description: 'Guarda hasta 10 configuraciones de filtros y reutilízalas sin tener que empezar desde cero.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>`,
    title: 'Gestión de acuerdos',
    description: 'Crea propuestas, negocia y gestiona el ciclo completo de los acuerdos de patrocinio desde la plataforma.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" /></svg>`,
    title: 'Mensajería directa',
    description: 'Comunícate directamente con los clubes desde la plataforma. Sin intermediarios, sin retrasos.',
  },
];
---

<section id="features" class="relative py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="max-w-2xl mb-20">
      <p class="text-xs font-medium uppercase tracking-widest text-secondary mb-4">Características</p>
      <h2 class="text-4xl md:text-5xl font-black tracking-tight text-on-surface mb-6" style="letter-spacing: -0.03em;">
        Todo lo que necesitas para encontrar el patrocinio ideal
      </h2>
      <p class="text-lg text-on-surface-variant leading-relaxed">
        Herramientas diseñadas para reducir el tiempo de descubrimiento a minutos y aumentar tu tasa de conversión.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((feature) => (
        <div class="group p-8 rounded-2xl bg-surface-container hover:bg-surface-bright transition-all duration-300 hover:shadow-[0_0_40px_rgba(37,99,235,0.08)]">
          <div class="w-12 h-12 rounded-xl bg-surface-low flex items-center justify-center text-primary mb-6 group-hover:bg-primary-container/20 transition-colors">
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="text-lg font-bold text-on-surface mb-3">{feature.title}</h3>
          <p class="text-sm text-on-surface-variant leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
