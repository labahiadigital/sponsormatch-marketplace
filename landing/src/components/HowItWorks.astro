---
const steps = [
  {
    number: '01',
    title: 'Define tus objetivos',
    description: '¿Buscas branding, conversión, contenido o experiencias? Configura tu perfil de marca con presupuesto, sector y objetivos. El Match Score se calcula automáticamente.',
  },
  {
    number: '02',
    title: 'Descubre tu match ideal',
    description: 'Explora clubes con métricas reales: seguidores, engagement, audiencias segmentadas y territorio único. Compara su alcance con medios locales.',
  },
  {
    number: '03',
    title: 'Analiza el ROI antes de invertir',
    description: 'Calcula el retorno estimado, revisa el plan de activación con acciones pre/durante/post evento, y evalúa el valor mediático antes de proponer nada.',
  },
  {
    number: '04',
    title: 'Propón, negocia y activa',
    description: 'Envía propuestas personalizadas con datos reales. Gestiona acuerdos, mensajes y seguimiento del patrocinio desde una sola plataforma.',
  },
];
---

<section id="how-it-works" class="relative py-32 bg-surface-low">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center max-w-2xl mx-auto mb-20">
      <p class="text-xs font-medium uppercase tracking-widest text-tertiary mb-4">Cómo funciona</p>
      <h2 class="text-4xl md:text-5xl font-black tracking-tight text-on-surface" style="letter-spacing: -0.03em;">
        Del descubrimiento al acuerdo rentable
      </h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step, index) => (
        <div class="relative">
          <div class="text-7xl font-black text-surface-bright mb-6" style="letter-spacing: -0.04em;">{step.number}</div>
          <h3 class="text-xl font-bold text-on-surface mb-3">{step.title}</h3>
          <p class="text-sm text-on-surface-variant leading-relaxed">{step.description}</p>
          {index < steps.length - 1 && (
            <div class="hidden lg:block absolute top-8 right-0 translate-x-1/2 w-12 h-px bg-outline-variant/30"></div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
