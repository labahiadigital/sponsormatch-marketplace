---
const testimonials = [
  {
    quote: 'Con la calculadora de ROI pudimos demostrar a dirección que el patrocinio generaría 3,4 veces más valor mediático que la inversión. Aprobaron el presupuesto en una semana.',
    name: 'María García',
    role: 'Directora de Marketing',
    company: 'TechFit Sports',
  },
  {
    quote: 'El plan de activación pre/durante/post fue lo que convenció a nuestro patrocinador. Ya no vendemos un espacio en la camiseta, vendemos una plataforma de comunicación completa.',
    name: 'Carlos Ruiz',
    role: 'Director Comercial',
    company: 'Club Deportivo Alavés',
  },
  {
    quote: 'El mapa de audiencias nos descubrió que nuestro perfil de fans era perfecto para marcas de lifestyle. Cerramos 3 acuerdos en un trimestre con el Match Score como argumento.',
    name: 'Ana Martínez',
    role: 'Responsable de Patrocinios',
    company: 'Surf Club Zarautz',
  },
];
---

<section id="testimonials" class="relative py-32 bg-surface-low">
  <div class="mx-auto max-w-7xl px-6">
    <div class="max-w-2xl mb-20">
      <p class="text-xs font-medium uppercase tracking-widest text-tertiary mb-4">Casos de éxito</p>
      <h2 class="text-4xl md:text-5xl font-black tracking-tight text-on-surface" style="letter-spacing: -0.03em;">
        Propiedades deportivas que ya enamoraron al patrocinador
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="p-8 rounded-2xl bg-surface-container hover:bg-surface-bright transition-all duration-300">
          <svg class="w-8 h-8 text-primary/30 mb-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151C7.563 6.068 6 8.789 6 11h4v10H0z" />
          </svg>
          <p class="text-base text-on-surface leading-relaxed mb-8">{t.quote}</p>
          <div>
            <p class="font-semibold text-on-surface">{t.name}</p>
            <p class="text-sm text-on-surface-variant">{t.role}, {t.company}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
