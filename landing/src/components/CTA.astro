<section class="relative py-32 overflow-hidden">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] rounded-full bg-primary-container/10 blur-[150px]"></div>
  </div>

  <div class="relative mx-auto max-w-4xl px-6 text-center">
    <h2 class="text-4xl md:text-6xl font-black tracking-tight text-on-surface mb-6" style="letter-spacing: -0.03em;">
      Empieza a conectar<br />
      <span class="text-primary">marca y deporte</span>
    </h2>
    <p class="text-lg text-on-surface-variant max-w-2xl mx-auto mb-12 leading-relaxed">
      Únete a cientos de marcas que ya están descubriendo oportunidades de patrocinio con datos reales y recomendaciones inteligentes.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/app" class="inline-flex items-center justify-center gap-2 px-10 py-4 rounded-lg bg-gradient-to-r from-primary-container to-secondary-container text-white font-semibold text-base hover:shadow-[0_0_30px_rgba(37,99,235,0.5)] transition-all duration-300 transform hover:-translate-y-0.5">
        Crear cuenta gratuita
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
